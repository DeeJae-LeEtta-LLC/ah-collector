# Example environment variables — copy to .env and fill in your values.

# OpenSea API key (required) — https://docs.opensea.io/reference/api-keys
OPENSEA_API_KEY=your_opensea_api_key_here

# Ethereum wallet address to use for purchasing NFTs (required)
WALLET_ADDRESS=0xYourWalletAddressHere

# Private key for the wallet above — NEVER commit this value to version control
# The bot reads this from the environment at runtime.
WALLET_PRIVATE_KEY=your_private_key_here

# Ethereum JSON-RPC URL (public endpoint or your own node)
ETH_RPC_URL=https://eth.llamarpc.com

# Set to "false" to enable real purchases (default: true — simulation only)
DRY_RUN=true

# How often the bot checks each collection, in seconds (minimum 10)
CHECK_INTERVAL_SECONDS=60

# Maximum gas price in Gwei — skip purchases if gas exceeds this
MAX_GAS_GWEI=50.0

# Ethereum network name (used by OpenSea API)
NETWORK=ethereum
